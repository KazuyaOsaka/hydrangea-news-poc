# Gemini API
GEMINI_API_KEY=AIza...

# ── 階層型モデルフォールバック (TIER1 → TIER4 の順に試行) ──────────────────────
# 429 Quota エラー時: 各 Tier を指数バックオフ 3回リトライ後に次 Tier へ切替
GEMINI_MODEL_TIER1=gemini-3.1-flash-preview-0419
GEMINI_MODEL_TIER2=gemini-3.1-flash-lite-preview
GEMINI_MODEL_TIER3=gemini-2.5-flash
GEMINI_MODEL_TIER4=gemini-2.5-flash-lite

# Paths (デフォルト値で動くので変更不要)
INPUT_DIR=data/input
OUTPUT_DIR=data/output
DB_PATH=data/db/hydrangea.db

# Logging
LOG_LEVEL=INFO

# ── 運用スケジュール ──────────────────────────────────────────────────────────
# 1日の実行回数 (スケジューラ設定の目安)
RUNS_PER_DAY=5
# 1日の最大公開件数 (超えると publish をスキップ)
MAX_PUBLISHES_PER_DAY=5

# ── LLM 呼び出し予算 ──────────────────────────────────────────────────────────
# 1回の実行あたりの上限 (cluster_merge + script + article で最大 ~12)
LLM_CALL_BUDGET_PER_RUN=12
# 1日あたりの上限 (5回 × 12 = 60 消費想定、余裕を持って 120)
LLM_CALL_BUDGET_PER_DAY=120
# normalized モード: JP クラスタ 1 件あたり比較する EN 候補数 (小さくするほど LLM 節約)
EN_CANDIDATES_PER_JP_CLUSTER=2
