# Gemini API
GEMINI_API_KEY=AIza...

# ── 階層型モデルフォールバック (TIER1 → TIER4 の順に試行) ──────────────────────
# E-3' 以降、役割別に異なる Tier 階層を使う:
#   - QUALITY 系統 (judge, script, article, title, analysis): GEMINI_MODEL_TIER1〜4
#   - LIGHTWEIGHT 系統 (garbage_filter, merge_batch, viral_filter, editorial_mission_filter):
#     GEMINI_LIGHTWEIGHT_TIER1〜4
# 429/503 エラー時: 各 Tier を MAX_ATTEMPTS 回リトライ後に次 Tier へ切替

# ── E-3': 性能タスク (judge, script, article, title, analysis) 用 Tier 階層 ──
# 公式の性能順 (gemini-3-flash-preview > gemini-2.5-flash > gemini-3.1-flash-lite-preview > gemini-2.5-flash-lite)
GEMINI_MODEL_TIER1=gemini-3-flash-preview            # 最高性能 Preview
GEMINI_MODEL_TIER2=gemini-2.5-flash                  # 高性能 GA (詳細推論)
GEMINI_MODEL_TIER3=gemini-3.1-flash-lite-preview    # 高速 Preview
GEMINI_MODEL_TIER4=gemini-2.5-flash-lite             # 最軽量 GA (最終安全網)

# ── E-3': 軽量タスク (garbage_filter, merge_batch, viral_filter, editorial_mission_filter) 用 Tier 階層 ──
# GA 主軸で 503 を回避し、試運転速度を最大化する
GEMINI_LIGHTWEIGHT_TIER1=gemini-2.5-flash               # GA, 高性能 (精度確保)
GEMINI_LIGHTWEIGHT_TIER2=gemini-2.5-flash-lite          # GA, 最軽量
GEMINI_LIGHTWEIGHT_TIER3=gemini-3.1-flash-lite-preview  # Preview, 緊急 fallback
GEMINI_LIGHTWEIGHT_TIER4=gemini-3-flash-preview         # Preview, 最終 fallback

# ── E-3': Tier ごとの MAX_ATTEMPTS (全 Tier 統一で 2 retry、失敗率約 0.002%) ──
GEMINI_QUALITY_MAX_ATTEMPTS=2
GEMINI_LIGHTWEIGHT_MAX_ATTEMPTS=2

# ── Gemini API 呼び出し間隔 (秒) — 各 Tier の RPM 上限を尊重 ────────────────────
# 安全マージン 70% 想定。
# TIER1 (gemini-3.1-flash-lite-preview, RPM=15): ~5.7s
# TIER2 (gemini-2.5-flash-lite,         RPM=10): ~8.6s
# TIER3 (gemini-3-flash-preview,         RPM=5): ~17.2s
# TIER4 (gemini-2.5-flash,               RPM=5): ~17.2s
GEMINI_CALL_INTERVAL_SEC_TIER1=5.7
GEMINI_CALL_INTERVAL_SEC_TIER2=8.6
GEMINI_CALL_INTERVAL_SEC_TIER3=17.2
GEMINI_CALL_INTERVAL_SEC_TIER4=17.2

# Paths (デフォルト値で動くので変更不要)
INPUT_DIR=data/input
OUTPUT_DIR=data/output
DB_PATH=data/db/hydrangea.db

# Logging
LOG_LEVEL=INFO

# ── 運用スケジュール ──────────────────────────────────────────────────────────
# 1日の実行回数 (スケジューラ設定の目安)
RUNS_PER_DAY=5

# ── F-16-A: per-run 上限 (cron 自動実行 × per-run 上限で公開頻度を制御) ──
# 真の本番運用 (F-16-B 実装後): cron 6 時間おき × 4 run/日
#   - 動画化対象 = 4 run × TOP_N_VIDEOS_PER_RUN   (default 1) = 4 動画/日
#   - 記事化対象 = 4 run × TOP_N_ARTICLES_PER_RUN (default 3) = 12 記事/日
# 設計上 video ⊆ article。video > article は無効でクランプされる。
TOP_N_VIDEOS_PER_RUN=1     # 1 run あたりの動画 (script + video) 生成数
TOP_N_ARTICLES_PER_RUN=3   # 1 run あたりの記事 (article) 生成数

# DEPRECATED (F-16-A で廃止予定): 1 日の最大公開件数。
# per-day 単一上限では Top-3 候補が 5 件上限で skip される事故 (試運転 7-I) が
# 発生したため撤廃。後方互換のため env / コードからは読み続けるが、
# default 999 で実質無効化。新環境では TOP_N_VIDEOS_PER_RUN /
# TOP_N_ARTICLES_PER_RUN を使うこと。
# MAX_PUBLISHES_PER_DAY=999

# ── LLM 呼び出し予算 ──────────────────────────────────────────────────────────
# 1回の実行あたりの上限 (cluster_merge + script + article で最大 ~12)
LLM_CALL_BUDGET_PER_RUN=12
# 1日あたりの上限 (5回 × 12 = 60 消費想定、余裕を持って 120)
LLM_CALL_BUDGET_PER_DAY=120
# normalized モード: JP クラスタ 1 件あたり比較する EN 候補数 (小さくするほど LLM 節約)
EN_CANDIDATES_PER_JP_CLUSTER=2

# ── 分析レイヤー（Phase 1: geo_lens 単独稼働） ────────────────────────────────
# false = 既存パイプラインのみ動作（デフォルト）
# true  = Recency Guard + 観点抽出 + LLM 多角的分析 + 洞察抽出 + 尺プロファイル選定
ANALYSIS_LAYER_ENABLED=false
# 分析レイヤーで使うチャンネル ID（configs/channels.yaml に定義された channel_id）
DEFAULT_CHANNEL_ID=geo_lens
# 分析レイヤーの LLM クライアント設定（事実重視）
ANALYSIS_LLM_TEMPERATURE=0.3
ANALYSIS_LLM_MAX_TOKENS=2000
# 1 run あたり分析レイヤーで消費しうる LLM 呼び出しの目安（観測用）
ANALYSIS_MAX_LLM_CALLS_PER_RUN=10
# Recency Guard: 直近 N 時間内の同一 entity/topic を降格する窓
RECENCY_GUARD_HOURS=24
# Recency Guard: 重複ヒット時のスコア倍率（0.5 = 半減）
RECENCY_GUARD_PENALTY=0.5
# DEPRECATED (F-16-A で TOP_N_ARTICLES_PER_RUN にリネーム):
# Top-N 台本生成: 分析レイヤー設計では 1 本フォーカス推奨。env 未指定時は 3（既存挙動）。
# F-4: AnalysisLayer を Top-N 全 Slot で実行する際の N 値も同じ env を再利用する。
# F-16-A: TOP_N_ARTICLES_PER_RUN が設定されていない場合の fallback default として
# 引き続き読まれる。新環境では TOP_N_ARTICLES_PER_RUN を使うこと。
# TOP_N_GENERATION=3

# ── Editorial Mission Filter（Hydrangea 編集ミッション適合度ゲート） ─────────
# 7軸 (perspective_gap / geopolitical_significance / blindspot_severity /
# political_intent / hidden_power_dynamics / economic_interests /
# discussion_potential) で「日本人に届けるべきニュース」を選別する。
# false で完全スキップ、スコアはセットされない。
EDITORIAL_MISSION_FILTER_ENABLED=true
# Step-1 prescore (静的ルール) から Step-2 LLM scoring に送る上位候補数
MISSION_PRESCORE_TOP_N=20
# Step-2 LLM scoring を実行するか（false にすると prescore のみ）
MISSION_LLM_ENABLED=true
# editorial_mission_score < この値の候補は生成前にドロップ（暫定値; 運用データで調整予定）
MISSION_SCORE_THRESHOLD=45.0
