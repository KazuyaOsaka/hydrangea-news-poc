# Gemini API
GEMINI_API_KEY=AIza...

# ── 階層型モデルフォールバック (TIER1 → TIER4 の順に試行) ──────────────────────
# 429 Quota エラー時: 各 Tier を指数バックオフ 3回リトライ後に次 Tier へ切替
GEMINI_MODEL_TIER1=gemini-3.1-flash-lite-preview
GEMINI_MODEL_TIER2=gemini-3-flash-preview
GEMINI_MODEL_TIER3=gemini-2.5-flash
GEMINI_MODEL_TIER4=gemini-2.5-flash-lite

# Paths (デフォルト値で動くので変更不要)
INPUT_DIR=data/input
OUTPUT_DIR=data/output
DB_PATH=data/db/hydrangea.db

# Logging
LOG_LEVEL=INFO

# ── 運用スケジュール ──────────────────────────────────────────────────────────
# 1日の実行回数 (スケジューラ設定の目安)
RUNS_PER_DAY=5
# 1日の最大公開件数 (超えると publish をスキップ)
MAX_PUBLISHES_PER_DAY=5

# ── LLM 呼び出し予算 ──────────────────────────────────────────────────────────
# 1回の実行あたりの上限 (cluster_merge + script + article で最大 ~12)
LLM_CALL_BUDGET_PER_RUN=12
# 1日あたりの上限 (5回 × 12 = 60 消費想定、余裕を持って 120)
LLM_CALL_BUDGET_PER_DAY=120
# normalized モード: JP クラスタ 1 件あたり比較する EN 候補数 (小さくするほど LLM 節約)
EN_CANDIDATES_PER_JP_CLUSTER=2

# ── 分析レイヤー（Phase 1: geo_lens 単独稼働） ────────────────────────────────
# false = 既存パイプラインのみ動作（デフォルト）
# true  = Recency Guard + 観点抽出 + LLM 多角的分析 + 洞察抽出 + 尺プロファイル選定
ANALYSIS_LAYER_ENABLED=false
# 分析レイヤーで使うチャンネル ID（configs/channels.yaml に定義された channel_id）
DEFAULT_CHANNEL_ID=geo_lens
# 分析レイヤーの LLM クライアント設定（事実重視）
ANALYSIS_LLM_TEMPERATURE=0.3
ANALYSIS_LLM_MAX_TOKENS=2000
# 1 run あたり分析レイヤーで消費しうる LLM 呼び出しの目安（観測用）
ANALYSIS_MAX_LLM_CALLS_PER_RUN=10
# Recency Guard: 直近 N 時間内の同一 entity/topic を降格する窓
RECENCY_GUARD_HOURS=24
# Recency Guard: 重複ヒット時のスコア倍率（0.5 = 半減）
RECENCY_GUARD_PENALTY=0.5
# Top-N 台本生成: 分析レイヤー設計では 1 本フォーカス推奨。env 未指定時は 3（既存挙動）。
TOP_N_GENERATION=3
