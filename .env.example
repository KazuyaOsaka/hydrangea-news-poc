# Gemini API
GEMINI_API_KEY=AIza...

# ── 階層型モデルフォールバック (TIER1 → TIER4 の順に試行) ──────────────────────
# 429 Quota エラー時: 各 Tier を指数バックオフ 3回リトライ後に次 Tier へ切替
# RPM 上限の高い順にフォールバック (15 → 10 → 5 → 5)
GEMINI_MODEL_TIER1=gemini-3.1-flash-lite-preview  # RPM=15, RPD=500
GEMINI_MODEL_TIER2=gemini-2.5-flash-lite          # RPM=10, RPD=20
GEMINI_MODEL_TIER3=gemini-3-flash-preview         # RPM=5,  RPD=20
GEMINI_MODEL_TIER4=gemini-2.5-flash               # RPM=5,  RPD=20

# ── Gemini API 呼び出し間隔 (秒) — 各 Tier の RPM 上限を尊重 ────────────────────
# 安全マージン 70% 想定。
# TIER1 (gemini-3.1-flash-lite-preview, RPM=15): ~5.7s
# TIER2 (gemini-2.5-flash-lite,         RPM=10): ~8.6s
# TIER3 (gemini-3-flash-preview,         RPM=5): ~17.2s
# TIER4 (gemini-2.5-flash,               RPM=5): ~17.2s
GEMINI_CALL_INTERVAL_SEC_TIER1=5.7
GEMINI_CALL_INTERVAL_SEC_TIER2=8.6
GEMINI_CALL_INTERVAL_SEC_TIER3=17.2
GEMINI_CALL_INTERVAL_SEC_TIER4=17.2

# Paths (デフォルト値で動くので変更不要)
INPUT_DIR=data/input
OUTPUT_DIR=data/output
DB_PATH=data/db/hydrangea.db

# Logging
LOG_LEVEL=INFO

# ── 運用スケジュール ──────────────────────────────────────────────────────────
# 1日の実行回数 (スケジューラ設定の目安)
RUNS_PER_DAY=5
# 1日の最大公開件数 (超えると publish をスキップ)
MAX_PUBLISHES_PER_DAY=5

# ── LLM 呼び出し予算 ──────────────────────────────────────────────────────────
# 1回の実行あたりの上限 (cluster_merge + script + article で最大 ~12)
LLM_CALL_BUDGET_PER_RUN=12
# 1日あたりの上限 (5回 × 12 = 60 消費想定、余裕を持って 120)
LLM_CALL_BUDGET_PER_DAY=120
# normalized モード: JP クラスタ 1 件あたり比較する EN 候補数 (小さくするほど LLM 節約)
EN_CANDIDATES_PER_JP_CLUSTER=2

# ── 分析レイヤー（Phase 1: geo_lens 単独稼働） ────────────────────────────────
# false = 既存パイプラインのみ動作（デフォルト）
# true  = Recency Guard + 観点抽出 + LLM 多角的分析 + 洞察抽出 + 尺プロファイル選定
ANALYSIS_LAYER_ENABLED=false
# 分析レイヤーで使うチャンネル ID（configs/channels.yaml に定義された channel_id）
DEFAULT_CHANNEL_ID=geo_lens
# 分析レイヤーの LLM クライアント設定（事実重視）
ANALYSIS_LLM_TEMPERATURE=0.3
ANALYSIS_LLM_MAX_TOKENS=2000
# 1 run あたり分析レイヤーで消費しうる LLM 呼び出しの目安（観測用）
ANALYSIS_MAX_LLM_CALLS_PER_RUN=10
# Recency Guard: 直近 N 時間内の同一 entity/topic を降格する窓
RECENCY_GUARD_HOURS=24
# Recency Guard: 重複ヒット時のスコア倍率（0.5 = 半減）
RECENCY_GUARD_PENALTY=0.5
# Top-N 台本生成: 分析レイヤー設計では 1 本フォーカス推奨。env 未指定時は 3（既存挙動）。
# F-4: AnalysisLayer を Top-N 全 Slot で実行する際の N 値も同じ env を再利用する。
# デフォルト 3 = Slot-1, Slot-2, Slot-3 全てで分析実行。
# 1 にすれば Slot-1 のみ実行 (F-3 以前の挙動に戻す)。
TOP_N_GENERATION=3

# ── Editorial Mission Filter（Hydrangea 編集ミッション適合度ゲート） ─────────
# 7軸 (perspective_gap / geopolitical_significance / blindspot_severity /
# political_intent / hidden_power_dynamics / economic_interests /
# discussion_potential) で「日本人に届けるべきニュース」を選別する。
# false で完全スキップ、スコアはセットされない。
EDITORIAL_MISSION_FILTER_ENABLED=true
# Step-1 prescore (静的ルール) から Step-2 LLM scoring に送る上位候補数
MISSION_PRESCORE_TOP_N=20
# Step-2 LLM scoring を実行するか（false にすると prescore のみ）
MISSION_LLM_ENABLED=true
# editorial_mission_score < この値の候補は生成前にドロップ（暫定値; 運用データで調整予定）
MISSION_SCORE_THRESHOLD=45.0
